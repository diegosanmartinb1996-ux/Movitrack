# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore private overrides, but allow the public .env (Sanity IDs)
.env*.local

# Claude Code local tooling (not part of the site)
/.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
